# Backend
CORS_ORIGINS=http://localhost:3000,https://confluence.website,https://www.confluence.website,https://confluence-visualization.vercel.app
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=confluence-dev-password
LOG_LEVEL=INFO

# AI Assistant (optional — works without these via built-in responses)
LLM_PROVIDER=groq              # openai | groq | anthropic
LLM_API_KEY=                   # Your API key
LLM_MODEL=qwen/qwen3-32b      # Model name (provider-specific)
RATE_LIMIT_LLM_PER_MINUTE=20   # Per-user rate limit for LLM calls

# Frontend (set NEXT_PUBLIC_API_URL to your Railway backend URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# SEO & Analytics
NEXT_PUBLIC_SITE_URL=https://confluence.website
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
